# Copy this file to `.sync.env` and fill local settings.
# Never commit `.sync.env`.
#
# Defaults:
# - If `.sync.env` is missing, sync is disabled.
# - If SYNC_INTERVAL_SECONDS is missing, scheduled sync uses 7200 seconds.

SYNC_ENABLED="false"
SYNC_INTERVAL_SECONDS="7200"

GIT_SYNC_ENABLED="true"

WEBDAV_SYNC_ENABLED="false"
WEBDAV_URL="http://example.local:5255/dav/sync/agentic-knowledge-vault"
WEBDAV_USER="admin"
WEBDAV_PASS="change-me"

MAC_SYNC_ENABLED="false"
MAC_SSH_HOST="10.106.106.5"
MAC_SSH_USER="shx"
MAC_VAULT_PATH="/Users/shx/Documents/Obsidian Vault/agentic-knowledge-vault"

